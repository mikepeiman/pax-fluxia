{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/territory-rules-hook.mjs",
            "timeout": 10,
            "statusMessage": "Re-injecting territory decision-point rules"
          }
        ]
      }
    ]
  }
}
