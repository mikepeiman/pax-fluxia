{
    "name": "pax-server",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "dev:node": "npx tsx --watch src/index.ts",
        "start": "bun src/index.ts",
        "start:prod": "bun run src/prod.ts",
        "build": "bun build src/index.ts --outdir dist --target node"
    },
    "dependencies": {
        "@pax/common": "workspace:*",
        "@colyseus/bun-websockets": "^0.17.6",
        "@colyseus/schema": "^4.0.0",
        "@colyseus/ws-transport": "^0.17.9",
        "colyseus": "0.17.8",
        "express": "^5.0.0"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "tsx": "^4.21.0",
        "typescript": "~5.6.2"
    }
}