{
    "name": "pax-fluxia-monorepo",
    "private": true,
    "packageManager": "bun@1.3.5",
    "workspaces": [
        "common",
        "pax-fluxia",
        "pax-server"
    ],
    "scripts": {
        "dev": "bun tools/dev/dev-full.ts",
        "dev:full": "bun tools/dev/dev-full.ts",
        "dev:client": "bun --cwd pax-fluxia run dev",
        "dev:server": "bun --cwd pax-server run dev:node",
        "build": "bun run --workspaces --if-present build",
        "agentic:pi": "pi",
        "agentic:context:build": "bun tools/agentic/build-context-pack.ts",
        "agentic:context:benchmark": "bun tools/agentic/benchmark-context-cache.ts",
        "debug:lane-margin": "bun tools/debug/diagnose-lane-margin.ts",
        "debug:lane-geometry": "bun tools/debug/inspect-lane-geometry.ts"
    },
    "dependencies": {
        "txtgen": "^3.0.7"
    },
    "devDependencies": {
        "@mariozechner/pi-coding-agent": "^0.66.1"
    }
}
